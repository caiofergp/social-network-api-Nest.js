generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String
  password          String
  token             String?   @unique
  expires_at        DateTime?
  email_verified_at DateTime?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  passwordResetTokens PasswordResetToken[]
  followers           Follow[]             @relation("followers")
  following           Follow[]             @relation("following")
  posts               Post[]
  likes               Like[]
  comments            Comment[]
  shareds             SharedPost[]

  @@map("users")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  token      String    @unique
  expires_at DateTime
  user_id    String
  used_at    DateTime?

  user User @relation(fields: [user_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("password_reset_tokens")
}

model Follow {
  follower_id  String
  following_id String
  created_at   DateTime @default(now())

  follower  User @relation("followers", fields: [follower_id], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [following_id], references: [id], onDelete: Cascade)

  @@id([follower_id, following_id])
  @@map("follows")
}

model Post {
  id      String  @id @default(uuid())
  content String?
  user_id String

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  user     User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  medias   PostMedia[]
  likes    Like[]       @relation("postLike")
  comments Comment[]
  shareds  SharedPost[]

  @@map("posts")
}

model PostMedia {
  id      String  @id @default(uuid())
  post_id String
  url     String?
  type    String
  path    String

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  post Post @relation(fields: [post_id], references: [id])

  @@map("post_media")
}

model Like {
  user_id      String
  reference_id String
  created_at   DateTime @default(now())
  type         String // post | comment

  user    User    @relation(fields: [user_id], references: [id])
  post    Post    @relation("postLike", fields: [reference_id], references: [id], map: "likes_post_reference_id_fkey")
  comment Comment @relation("commentLike", fields: [reference_id], references: [id], map: "likes_comment_reference_id_fkey")

  @@id([user_id, reference_id])
  @@map("likes")
}

model Comment {
  id        String  @id @default(uuid())
  user_id   String
  post_id   String
  parent_id String?
  content   String

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  user     User      @relation(fields: [user_id], references: [id])
  post     Post      @relation(fields: [post_id], references: [id])
  parent   Comment?  @relation("parent", fields: [parent_id], references: [id])
  children Comment[] @relation("parent")
  likes    Like[]    @relation("commentLike")

  @@map("comments")
}

model SharedPost {
  id      String @id @default(uuid())
  post_id String
  user_id String

  created_at DateTime @default(now())

  post Post @relation(fields: [post_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@map("shared_posts")
}
